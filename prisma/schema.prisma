generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ClinicRole {
  Chiropractor
  Receptionist
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
}

model User {
  id                   Int             @id @default(autoincrement())
  name                 String
  email                String          @unique
  phone                String?
  password             String
  role                 ClinicRole
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  providedAppointments Appointment[]   @relation("ProviderAppointments")
  createdAppointments  Appointment[]   @relation("CreatorAppointments")
  providerShifts       ProviderShift[] @relation("ProviderShifts")
  shiftUpdates         ProviderShift[] @relation("ShiftUpdatedBy")

  @@index([role])
}

/// Chiropractor working hours for a clinic calendar day (admin-maintained).
model ProviderShift {
  id              Int      @id @default(autoincrement())
  providerId      Int
  provider        User     @relation("ProviderShifts", fields: [providerId], references: [id], onDelete: Cascade)
  shiftDate       DateTime @db.Date
  startTime       DateTime
  endTime         DateTime
  notes           String?
  updatedByUserId Int?
  updatedBy       User?    @relation("ShiftUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([providerId, shiftDate])
  @@index([shiftDate])
  @@index([startTime, endTime])
}

model Patient {
  id              Int           @id @default(autoincrement())
  firstName       String
  lastName        String
  phone           String
  email           String?
  ahcNumber       String?
  dob             String?
  reminderOptIn   Boolean       @default(true)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  appointments    Appointment[]
  cards           Card[]
}

model Appointment {
  id               Int                @id @default(autoincrement())
  status           AppointmentStatus
  type             String
  startTime        DateTime
  endTime          DateTime
  slot             Int       @default(1)
  patientId        Int
  patient          Patient   @relation(fields: [patientId], references: [id])
  providerId       Int?
  provider         User?     @relation("ProviderAppointments", fields: [providerId], references: [id])
  createdByUserId  Int?
  createdBy        User?     @relation("CreatorAppointments", fields: [createdByUserId], references: [id])
  requestMessage   String?
  adminNotes       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  reminderSent     Boolean   @default(false)
  reminderSentAt   DateTime?
  payment          Payment?

  @@index([startTime])
  @@index([providerId, startTime])
  @@index([patientId])
  @@index([status, reminderSent])
}

model Payment {
  id            Int         @id @default(autoincrement())
  amount        Decimal
  paymentType   String
  receiptSent   Boolean     @default(false)
  createdAt     DateTime    @default(now())

  appointmentId Int         @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
}

model Card {
  id          Int      @id @default(autoincrement())
  brand       String
  last4       String
  expMonth    Int?
  expYear     Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patientId   Int
  patient     Patient  @relation(fields: [patientId], references: [id])

  @@index([patientId])
}